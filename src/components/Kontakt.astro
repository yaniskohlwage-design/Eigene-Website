---
---

<section id="kontakt" class="py-24 bg-black">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Left: Info -->
      <div class="contact-info">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Lass uns reden.</h2>
        <p class="text-white/70 leading-relaxed mb-10">
          Du hast Fragen oder willst direkt loslegen? Schreib mir — ich melde mich innerhalb von 24 Stunden.
          Kein Auftrag zu klein, kein Business zu speziell.
        </p>

        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p class="text-white/40 text-xs uppercase tracking-wider mb-1">E-Mail</p>
              <a href="mailto:kontakt@fatedesign.studio" class="text-white hover:text-white/80 transition-colors">
                kontakt@fatedesign.studio
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.54a16 16 0 0 0 6.55 6.55l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <p class="text-white/40 text-xs uppercase tracking-wider mb-1">Telefon</p>
              <a href="tel:+4915226903496" class="text-white hover:text-white/80 transition-colors">
                +49 152 26903496
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="text-white/40 text-xs uppercase tracking-wider mb-1">Standort</p>
              <span class="text-white">Hamburg, Deutschland</span>
            </div>
          </div>
        </div>

        <div class="mt-10 p-4 rounded-xl bg-white/5 border border-white/10">
          <p class="text-white/60 text-sm">
            <span class="text-white font-medium">Antwortzeit:</span> Ich melde mich innerhalb von 24h — garantiert.
          </p>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="contact-form">
        <div id="success-banner" class="hidden mb-6 p-4 bg-white/10 border border-white/20 rounded-xl">
          <p class="text-white font-medium">Danke für deine Nachricht!</p>
          <p class="text-white/60 text-sm mt-1">Ich melde mich innerhalb von 24 Stunden bei dir.</p>
        </div>

        <form
          name="kontakt"
          method="POST"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          action="/danke"
          class="space-y-5"
        >
          <input type="hidden" name="form-name" value="kontakt" />
          <div class="hidden">
            <label>Nicht ausfüllen: <input name="bot-field" /></label>
          </div>

          <div>
            <label for="name" class="block text-white/70 text-sm mb-2">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Max Mustermann"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-white/40 focus:bg-white/8 transition-all"
            />
          </div>

          <div>
            <label for="email" class="block text-white/70 text-sm mb-2">E-Mail *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="max@beispiel.de"
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-white/40 focus:bg-white/8 transition-all"
            />
          </div>

          <div>
            <label for="nachricht" class="block text-white/70 text-sm mb-2">Nachricht *</label>
            <textarea
              id="nachricht"
              name="nachricht"
              required
              rows="5"
              placeholder="Erzähl mir kurz von deinem Business und was du brauchst..."
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-white/30 focus:outline-none focus:border-white/40 focus:bg-white/8 transition-all resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-white text-black font-semibold py-4 rounded-xl hover:bg-gray-100 transition-colors flex items-center justify-center gap-2"
          >
            Nachricht senden
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  if (new URLSearchParams(window.location.search).get("success") === "true") {
    document.getElementById("success-banner")?.classList.remove("hidden")
  }

  const elements = document.querySelectorAll(".contact-info, .contact-form")
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            ;(entry.target as HTMLElement).style.opacity = "1"
            ;(entry.target as HTMLElement).style.transform = "translateY(0)"
          }, i * 150)
          observer.unobserve(entry.target)
        }
      })
    },
    { threshold: 0.1 }
  )

  elements.forEach((el) => {
    ;(el as HTMLElement).style.opacity = "0"
    ;(el as HTMLElement).style.transform = "translateY(24px)"
    ;(el as HTMLElement).style.transition = "opacity 0.7s ease, transform 0.7s ease"
    observer.observe(el)
  })
</script>
